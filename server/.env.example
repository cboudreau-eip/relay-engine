# RankPilot TiDB connection (read-only access to the content pipeline DB)
RANKPILOT_DATABASE_URL=mysql://user:password@host:4000/database?ssl={"rejectUnauthorized":true}

# Session signing secret — any long random string (keep this private)
JWT_SECRET=change-me-to-a-long-random-string

# Dashboard login password — what you type on the /login page
DASHBOARD_PASSWORD=change-me-to-your-password
